# MongoDB Configuration
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=itr_filing

# CSFLE Security (96-byte base64 encoded master key)
CSFLE_MASTER_KEY=your_96_byte_base64_master_key_here
CSFLE_KEY_VAULT_NAMESPACE=encryption.__keyVault

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Storage Configuration (Azure)
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_STORAGE_CONTAINER_NAME=itr-extractions

# Auth Security
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=1

# Seed User Configuration
SEED_FIRST_NAME=Firstname
SEED_MIDDLE_NAME=Middlename
SEED_LAST_NAME=Lastname
SEED_PAN_NUMBER=ABCDE1234F
SEED_AADHAR_NUMBER=123456789012
SEED_AADHAR_PINCODE=400001
SEED_MOBILE_NUMBER=9876543210
SEED_EMAIL=user@example.com
SEED_PASSWORD=secure_password_here
SEED_ROLE=admin
SEED_IS_ACTIVE=true
